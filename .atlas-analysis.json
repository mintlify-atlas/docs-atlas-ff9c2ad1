  "publicApiSurface": [
    "useAsset() - Hook for accessing asset metadata and state",
    "useProfile() - Hook for user profile and ENS data",
    "useBalance() - Hook for wallet balance information",
    "queryMetadata() - Query assets from Aquarius metadata cache",
    "getEncryptedFiles() - Retrieve encrypted file information",
    "downloadFile() - Download asset files with access control",
    "AssetActions - Component for asset interactions",
    "Publish - Component for creating new data assets",
    "Search - Component for discovering assets",
    "VerifiablePresentation - Component for credential verification",
    "/api/services - API endpoint for service offerings",
    "/api/faucet - API endpoint for test token requests"
